<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anxon - Tu Red de Video</title>
    <style>
        /* Estilo General - Inspiración Dark/Tech */
        body {
            background-color: #050505;
            color: #ffffff;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }

        /* El Logo Anxon */
        .logo {
            font-size: 4rem;
            font-weight: bold;
            letter-spacing: -2px;
            color: #008cff;
            text-shadow: 0 0 20px rgba(0, 140, 255, 0.5);
            margin-bottom: 10px;
        }

        .welcome-text {
            font-size: 1.5rem;
            color: #888;
            margin-bottom: 30px;
            font-style: italic;
        }

        /* Botones Principales */
        .btn-container { display: flex; gap: 20px; }

        .btn {
            background: transparent;
            border: 1px solid #008cff;
            color: #008cff;
            padding: 12px 30px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
            text-decoration: none;
        }

        .btn:hover {
            background: #008cff;
            color: white;
            box-shadow: 0 0 15px #008cff;
        }

        /* Ventana de Registro/Login (Modal) */
        .modal {
            display: none; /* Escondido por defecto */
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(10px); /* Efecto cristal */
            justify-content: center;
            align-items: center;
            z-index: 100;
        }

        .modal-content {
            background: rgba(20, 20, 20, 0.9);
            padding: 40px;
            border-radius: 20px;
            border: 1px solid #333;
            width: 350px;
            text-align: center;
            box-shadow: 0 0 30px rgba(0, 140, 255, 0.2);
        }

        input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            background: #111;
            border: 1px solid #333;
            border-radius: 10px;
            color: white;
            box-sizing: border-box;
        }

        .btn-full { width: 100%; margin-top: 15px; }

        .close-btn {
            color: #555;
            cursor: pointer;
            float: right;
            font-size: 20px;
        }

        .close-btn:hover { color: white; }

        /* Animaciones */
        .fade-in { animation: fadeIn 1.5s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <div class="logo fade-in">ANXON</div>
    <div class="welcome-text fade-in">Bienvenido/a al anexo</div>

    <div class="btn-container fade-in">
        <a href="#" class="btn" onclick="alert('Próximamente: Muro de Videos')">Explorar Videos</a>
        <a href="#" class="btn" style="background: #008cff; color: white;" onclick="openModal()">Entrar al Anexo</a>
    </div>

    <div id="authModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal()">&times;</span>
            <h2 id="modalTitle" style="color: #008cff;">Iniciar Sesión</h2>
            <input type="email" id="email" placeholder="Email">
            <input type="password" id="pass" placeholder="Contraseña">
            <button class="btn btn-full" style="background: #008cff; color: white;" onclick="handleAuth()">Acceder</button>
            <p style="font-size: 12px; color: #666; margin-top: 20px; cursor: pointer;" onclick="toggleAuth()">¿No tienes cuenta? Regístrate aquí</p>
        </div>
    </div>

    <script>
        const modal = document.getElementById("authModal");
        let isLogin = true;

        function openModal() { modal.style.display = "flex"; }
        function closeModal() { modal.style.display = "none"; }

        function toggleAuth() {
            isLogin = !isLogin;
            document.getElementById("modalTitle").innerText = isLogin ? "Iniciar Sesión" : "Crear Cuenta";
        }

        function handleAuth() {
            const email = document.getElementById("email").value;
            if(email === "") {
                alert("Por favor, ingresa un correo para el anexo.");
                return;
            }
            // Aquí conectaremos Firebase luego
            alert(isLogin ? "¡Bienvenido de vuelta a Anxon!" : "Cuenta creada. Bienvenido al anexo.");
            closeModal();
        }

        // Cerrar si clic afuera
        window.onclick = function(event) {
            if (event.target == modal) closeModal();
        }
    </script>

</body>
</html>
