<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anxon - Red Social de Video</title>
    <style>
        :root {
            --accent: #008cff;
            --bg: #050505;
            --glass: rgba(20, 20, 20, 0.85);
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: var(--bg);
            color: white;
            font-family: 'Segoe UI', Roboto, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* Fondo con puntos decorativos */
        .bg-dots {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: radial-gradient(var(--accent) 0.5px, transparent 0.5px);
            background-size: 30px 30px;
            opacity: 0.1;
            z-index: -1;
        }

        .container {
            text-align: center;
            z-index: 10;
        }

        .logo {
            font-size: clamp(3rem, 10vw, 5rem);
            font-weight: 900;
            letter-spacing: -3px;
            color: var(--accent);
            text-shadow: 0 0 30px rgba(0, 140, 255, 0.4);
            margin: 0;
        }

        .welcome-text {
            font-size: 1.2rem;
            color: #777;
            margin-bottom: 40px;
            font-style: italic;
            letter-spacing: 1px;
        }

        .btn-group {
            display: flex;
            gap: 15px;
            justify-content: center;
        }

        .btn {
            padding: 14px 28px;
            border-radius: 50px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-decoration: none;
            font-size: 1rem;
            border: 2px solid var(--accent);
        }

        .btn-outline {
            color: var(--accent);
            background: transparent;
        }

        .btn-primary {
            background: var(--accent);
            color: white;
        }

        .btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(0, 140, 255, 0.4);
        }

        /* MODAL */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(8px);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal-box {
            background: var(--glass);
            padding: 40px;
            border-radius: 24px;
            border: 1px solid #333;
            width: 90%;
            max-width: 360px;
            position: relative;
        }

        input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            background: #000;
            border: 1px solid #444;
            border-radius: 8px;
            color: white;
            box-sizing: border-box;
        }

        .btn-block { width: 100%; margin-top: 10px; }

        .fade-in { animation: fadeIn 1s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <div class="bg-dots"></div>

    <div class="container fade-in">
        <h1 class="logo">ANXON</h1>
        <p class="welcome-text">Bienvenido/a al anexo</p>
        
        <div class="btn-group">
            <a href="#" class="btn btn-outline" onclick="alert('Accediendo al servidor de videos...')">Explorar</a>
            <a href="#" class="btn btn-primary" onclick="toggleModal(true)">Registrarse</a>
        </div>
    </div>

    <div id="modal" class="modal-overlay" onclick="closeOutside(event)">
        <div class="modal-box fade-in">
            <h2 id="mTitle" style="margin-top:0; color:var(--accent)">Crear Cuenta</h2>
            <input type="email" id="email" placeholder="Correo electrónico">
            <input type="password" id="pass" placeholder="Contraseña">
            <button class="btn btn-primary btn-block" onclick="authAction()">Continuar</button>
            <p id="mSwitch" style="font-size:0.8rem; color:#aaa; margin-top:20px; cursor:pointer; text-align:center" onclick="switchMode()">
                ¿Ya tienes cuenta? Inicia sesión
            </p>
        </div>
    </div>

    <script>
        const modal = document.getElementById('modal');
        let isLogin = false;

        function toggleModal(show) {
            modal.style.display = show ? 'flex' : 'none';
        }

        function closeOutside(e) {
            if(e.target === modal) toggleModal(false);
        }

        function switchMode() {
            isLogin = !isLogin;
            document.getElementById('mTitle').innerText = isLogin ? 'Iniciar Sesión' : 'Crear Cuenta';
            document.getElementById('mSwitch').innerText = isLogin ? '¿No tienes cuenta? Regístrate' : '¿Ya tienes cuenta? Inicia sesión';
        }

        function authAction() {
            const mail = document.getElementById('email').value;
            if(!mail) return alert("Ingresa un correo");
            alert(isLogin ? "Buscando credenciales en el anexo..." : "Usuario registrado en el anexo.");
            toggleModal(false);
        }
    </script>

</body>
</html>
